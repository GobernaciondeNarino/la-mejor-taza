# =========================================================================
# La Mejor Taza — .htaccess
# -------------------------------------------------------------------------
# Front controller estilo WordPress: cualquier URL que no resuelva a un
# archivo o directorio real se sirve a través de app.php (que decide si
# redirigir al asistente de instalación o renderizar la SPA).
#
# Funciona idéntico en la raíz del dominio o en un subdirectorio
# (p. ej. https://cisna.narino.gov.co/lamejortaza/), porque todas las
# reglas son relativas — no se asume ningún prefijo en disco.
#
# Requisitos del hosting:
#   - Apache 2.4+ (Apache 2.2.16+ también vale por FallbackResource).
#   - mod_rewrite habilitado, o en su defecto FallbackResource permitido.
#   - AllowOverride All (o al menos: FileInfo Indexes Options Limit).
# =========================================================================

# 1) Defaults ---------------------------------------------------------------
Options -Indexes -MultiViews
DirectoryIndex index.php app.php index.html

# 2) Bloqueo de archivos sensibles ------------------------------------------
# - Cualquier archivo "oculto" (.git, .env, .htaccess.bak, etc.)
# - Logs, dumps, copias de seguridad, archivos de editor.
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
<FilesMatch "\.(env|ini|log|sql|sqlite|sqlite3|md|sample|example|bak|backup|swp|swo|tmp|lock|orig|save)$">
  Require all denied
</FilesMatch>

# Archivos del backend que no deben servirse jamás como estáticos.
<Files "config.php">
  Require all denied
</Files>
<Files "router.php">
  Require all denied
</Files>
<Files "composer.json">
  Require all denied
</Files>
<Files "composer.lock">
  Require all denied
</Files>
<Files "package.json">
  Require all denied
</Files>

# Bloqueo recursivo de directorios internos (compatibilidad mod_alias /
# mod_rewrite — Apache no soporta DirectoryMatch global aquí, así que
# además filtramos por mod_rewrite más abajo).
RedirectMatch 403 (?i)/(\.git|\.svn|\.hg|node_modules|vendor)(/|$)
RedirectMatch 403 (?i)/(api/(config|lib|routes)|db)(/|$)
RedirectMatch 403 (?i)\.(sqlite|sqlite3|sql|env|ini|log)$

# 3) Cabeceras de seguridad -------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options          "nosniff"
  Header always set X-Frame-Options                 "SAMEORIGIN"
  Header always set Referrer-Policy                 "strict-origin-when-cross-origin"
  Header always set Permissions-Policy              "camera=(), microphone=(), geolocation=(), interest-cohort=()"
  Header always set Cross-Origin-Opener-Policy      "same-origin"
  Header always set Cross-Origin-Resource-Policy    "same-site"
  # HSTS sólo si la respuesta viaja por TLS.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" "expr=%{HTTPS} == 'on'"

  # Sin caché para HTML (lo dinámico): el SPA no puede quedarse pegado.
  <FilesMatch "\.(php|html)$">
    Header set Cache-Control "no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# 4) Front controller -------------------------------------------------------
# Estrategia A (preferida): mod_rewrite.
<IfModule mod_rewrite.c>
  RewriteEngine On

  # /api/... → api/index.php (preservando query string)
  RewriteRule ^api/?$    api/index.php  [L,QSA]
  RewriteRule ^api/.*$   api/index.php  [L,QSA]

  # Bloquear el acceso directo a librerías y rutas internas de la API.
  RewriteRule ^api/(config|lib|routes)(/|$) - [F,L]

  # Si el path apunta a un archivo o directorio real → servirlo tal cual.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Cualquier otra ruta → app.php (SPA + redirección al wizard si hace falta).
  RewriteRule ^ app.php [L]
</IfModule>

# Estrategia B (fallback): FallbackResource — soportada por Apache 2.2.16+.
# Si mod_rewrite no está cargado, esto cubre las rutas profundas de la SPA.
<IfModule !mod_rewrite.c>
  FallbackResource /app.php
</IfModule>

# 5) Compresión -------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# 6) Cache de estáticos -----------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                            "access plus 1 hour"
  ExpiresByType text/html                   "access plus 0 seconds"
  ExpiresByType text/css                    "access plus 1 hour"
  ExpiresByType application/javascript      "access plus 1 hour"
  ExpiresByType image/svg+xml               "access plus 1 day"
  ExpiresByType image/png                   "access plus 7 days"
  ExpiresByType image/jpeg                  "access plus 7 days"
  ExpiresByType image/webp                  "access plus 7 days"
  ExpiresByType image/x-icon                "access plus 30 days"
  ExpiresByType font/woff                   "access plus 30 days"
  ExpiresByType font/woff2                  "access plus 30 days"
</IfModule>

# 7) MIME types adicionales -------------------------------------------------
<IfModule mod_mime.c>
  AddType application/javascript        .js .jsx
  AddType application/json              .json
  AddType image/svg+xml                 .svg
  AddType font/woff2                    .woff2
</IfModule>

# 8) PHP defaults seguros (si el host permite php_value) --------------------
<IfModule mod_php.c>
  php_flag display_errors off
  php_flag log_errors on
  php_value max_input_vars 200
  php_value upload_max_filesize 8M
  php_value post_max_size 8M
</IfModule>
<IfModule mod_php7.c>
  php_flag display_errors off
  php_flag log_errors on
</IfModule>
<IfModule mod_php8.c>
  php_flag display_errors off
  php_flag log_errors on
</IfModule>
