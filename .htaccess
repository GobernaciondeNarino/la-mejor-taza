# =========================================================================
# La Mejor Taza — .htaccess (raíz)
# -------------------------------------------------------------------------
# Mínimo absoluto y compatible con Apache 2.2 y 2.4. Toda directiva
# "delicada" (Options, FilesMatch con Require, expr=) se ha removido o
# envuelto en <IfModule> para que un host con AllowOverride restrictivo
# NO devuelva 500. La defensa real está dentro de PHP (LMT_GUARD).
# =========================================================================

DirectoryIndex index.php app.php index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # /api/* siempre va al front controller PHP. Preserva el query string.
  RewriteRule ^api/?$    api/index.php  [L,QSA]
  RewriteRule ^api/.*$   api/index.php  [L,QSA]

  # Si la URL apunta a un archivo o directorio real, servirlo tal cual.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Cualquier otra ruta (deep link de la SPA) → app.php
  RewriteRule ^ app.php [L]
</IfModule>

# Fallback cuando mod_rewrite no está disponible.
<IfModule !mod_rewrite.c>
  <IfModule mod_dir.c>
    FallbackResource /index.php
  </IfModule>
</IfModule>

# Cache control sólo si mod_headers existe.
<IfModule mod_headers.c>
  <FilesMatch "\.(php|html)$">
    Header set Cache-Control "no-store, no-cache, must-revalidate"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Compresión opcional.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
