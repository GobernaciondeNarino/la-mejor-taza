# /lamejortaza/.htaccess — La Mejor Taza (instalado en subdirectorio)

Options -Indexes -MultiViews

# 1) Bloquear archivos sensibles
<FilesMatch "(^\.|\.(env|ini|log|sql|md|sample|example|bak|backup|swp|swo|tmp|sqlite|sqlite3))$">
    Require all denied
</FilesMatch>
<FilesMatch "^(config\.php|composer\.(json|lock))$">
    Require all denied
</FilesMatch>

# 2) Cabeceras de seguridad
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
</IfModule>

# 3) Rewrites para SPA + QR cortos /s/{id}, conscientes del subdirectorio
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /lamejortaza/

    # Si no hay api/config.php, redirige a install.php (sólo para home y SPA)
    RewriteCond %{DOCUMENT_ROOT}/lamejortaza/api/config.php !-f
    RewriteCond %{REQUEST_URI} !^/lamejortaza/install\.php
    RewriteCond %{REQUEST_URI} !^/lamejortaza/api(/|$)
    RewriteCond %{REQUEST_URI} ^/lamejortaza/(|index\.html|s/[a-z0-9\-]{2,32}/?|La%20Mejor%20Taza\.html)$
    RewriteRule ^ /lamejortaza/install.php [L,R=302]

    # /s/{id} → la SPA
    RewriteRule ^s/[a-z0-9\-]{2,32}/?$ "La Mejor Taza.html" [L]

    # / → la SPA
    RewriteRule ^$ "La Mejor Taza.html" [L]
</IfModule>

# 4) Compresión y cache
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                "access plus 1 hour"
    ExpiresByType application/javascript  "access plus 1 hour"
    ExpiresByType image/svg+xml           "access plus 1 day"
    ExpiresByType image/png               "access plus 7 days"
    ExpiresByType image/jpeg              "access plus 7 days"
    ExpiresByType image/webp              "access plus 7 days"
    ExpiresByType font/woff2              "access plus 30 days"
</IfModule>
