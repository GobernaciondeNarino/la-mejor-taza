# =========================================================================
# api/.htaccess — mínimo y bulletproof.
# -------------------------------------------------------------------------
# La API se llama directamente como `index.php?path=auth/me`, así que este
# .htaccess casi no necesita reglas. La protección real de archivos
# sensibles (config.php, lib/, routes/) está dentro de PHP vía
# LMT_GUARD — funciona aunque el hosting ignore .htaccess.
# =========================================================================

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Si mod_rewrite existe y la URL no es un archivo/dir real, usa el front
  # controller. Esto permite tanto /api/index.php?path=foo (siempre)
  # como /api/foo (sólo con rewrite).
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.php [L,QSA]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Cache-Control "no-store, no-cache, must-revalidate"
</IfModule>
